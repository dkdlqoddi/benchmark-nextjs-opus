// Prisma schema for HabitLog.
// Docs: https://pris.ly/d/prisma-schema
//
// Note: SQLite does not enforce string length limits. The data-model
// constraints (Habit.name 1-50 chars, Habit.description <= 200 chars, and
// color as a #RRGGBB hex string) are enforced in the Server Actions layer
// (see actions/habits.ts). Passwords are stored only as bcrypt hashes; all
// per-user data access is scoped by Habit.userId (see lib/auth.ts + actions).

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model User {
  id           String   @id @default(cuid())
  email        String   @unique
  name         String?
  passwordHash String
  createdAt    DateTime @default(now())
  habits       Habit[]
  tags         Tag[]
}

model Habit {
  id          String    @id @default(cuid())
  userId      String
  user        User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  name        String
  description String?
  color       String
  // Target weekdays as a 7-bit mask (bit i = weekday i, 0=Sun..6=Sat).
  // 127 = every day; existing habits default to every day. See lib/target-days.ts.
  targetDays  Int       @default(127)
  createdAt   DateTime  @default(now())
  archivedAt  DateTime?
  checkIns    CheckIn[]
  tags        Tag[]

  @@index([userId])
}

model CheckIn {
  id        String   @id @default(cuid())
  habitId   String
  habit     Habit    @relation(fields: [habitId], references: [id], onDelete: Cascade)
  date      String   // stored as YYYY-MM-DD
  createdAt DateTime @default(now())

  // A habit can only be checked in once per day.
  @@unique([habitId, date])
}

model Tag {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  name      String
  createdAt DateTime @default(now())
  habits    Habit[]

  // Tags are per-user; a user cannot have two tags with the same name.
  @@unique([userId, name])
  @@index([userId])
}
