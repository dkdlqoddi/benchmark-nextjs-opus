# Local SQLite database for development.
# Prisma resolves this relative path against prisma/schema.prisma, so the
# database file lives at prisma/dev.db.
DATABASE_URL="file:./dev.db"

# Auth.js (NextAuth v5) secret used to sign/encrypt session JWTs.
# This is a local development-only value committed for reproducibility;
# generate a fresh secret for any real deployment (`openssl rand -base64 33`).
AUTH_SECRET="KB98CFJ+rD/T//TBcEqQYUmqzA3nmD+sQ5jsAeb6oFE5"
